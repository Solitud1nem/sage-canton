# sage-canton backend — environment (copy to backend/.env, fill the secret from the Seaport PDF).
# .env is git-ignored; NEVER commit real secrets. Non-secret values below are safe defaults —
# blank lines fall back to the baked-in defaults in config.ts, so you only MUST set the secret.

# --- Deployment target: 'localnet' (default) or 'seaport-devnet' ---
LEDGER_TARGET=seaport-devnet

# --- Seaport DevNet target (5n sandbox shared validator) ---
SEAPORT_LEDGER_URL=https://ledger-api.validator.devnet.sandbox.fivenorth.io
SEAPORT_WS_URL=wss://ledger-api.validator.devnet.sandbox.fivenorth.io
SEAPORT_OIDC_TOKEN_URL=https://auth.sandbox.fivenorth.io/application/o/token/
SEAPORT_CLIENT_ID=validator-devnet-m2m
SEAPORT_CLIENT_SECRET=__PUT_THE_SECRET_FROM_THE_PDF_HERE__
SEAPORT_AUDIENCE=validator-devnet-m2m
SEAPORT_SCOPE=daml_ledger_api

# --- Parties (fill after the party model is decided; §5 of the runbook) ---
SAGE_PROVIDER_PARTY=
SAGE_REQUESTER_PARTY=
SAGE_WORKER_PARTY=
SAGE_ARBITER_PARTY=

# --- Optional overrides ---
# ADMIN_USER=
# PACKAGE_ID=
# PORT=

# --- Agent LLM (leave ANTHROPIC_API_KEY unset for a $0 offline deterministic run) ---
# ANTHROPIC_API_KEY=sk-ant-...      # set → live web-search research; unset → free offline stub
# LLM_MODEL=claude-haiku-4-5        # orchestrator/decompose model (cheap planning)
# RESEARCH_MODEL=claude-sonnet-5    # research model (needs web-search support: Sonnet 5/4.6 or Opus 4.x)
# RESEARCH_MAX_USES=1               # cheap testing: cap web-search rounds per sub-task (default 4–6)
# RESEARCH_EFFORT=low               # cheap testing: thinking depth (low|medium|high; default medium)

# --- LocalNet target (defaults are baked in; override only if your ports differ) ---
# LEDGER_API=
# VALIDATOR_API=
# REGISTRY_API=
# REGISTRY_HOST=
# AUTH_SECRET=
# AUTH_AUDIENCE=
