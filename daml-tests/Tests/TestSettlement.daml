-- | M3 settlement tests — REAL token movement via the CIP-0056 Allocation/DvP flow.
--
-- These exercise TaskEscrow against the Amulet (Canton Coin) registry using the
-- `splice-token-standard-test` mock registry, entirely in Daml Script (no LocalNet
-- needed). They prove that on settlement, funds actually move requester -> worker —
-- not just a status flip. Mirrors cn-quickstart's `licensing-tests` TestLicense flow.
--
-- The instrument here is Amulet; swapping to USDCx is a config change (ADR-0017).

module Tests.TestSettlement where

import Daml.Script hiding (Created)
import DA.Assert ((===))
import DA.List (head, sortOn)
import DA.Map qualified as Map
import DA.Time (addRelTime, seconds)

import Splice.Api.Token.MetadataV1 (ExtraArgs(..), emptyMetadata)
import Splice.Api.Token.AllocationV1 (Allocation, AllocationView)
import Splice.Api.Token.AllocationInstructionV1 (AllocationFactory_Allocate(..))

import Splice.AmuletAllocation (AmuletAllocation)

import Splice.Testing.Registries.AmuletRegistry qualified as AmuletRegistry
import Splice.Testing.TokenStandard.RegistryApi qualified as RegistryApi
import Splice.Testing.TokenStandard.WalletClient qualified as WalletClient
import Splice.Testing.Utils (emptyExtraArgs, submitWithDisclosures', queryDisclosure')

import TaskEscrow

-- Find the funded allocation that backs a given escrow, by its settlement reference id.
allocationForTask : Party -> Text -> Script (ContractId Allocation, AllocationView)
allocationForTask p refId = do
  allocs <- queryInterface @Allocation p
  let matching =
        [ (cid, a)
        | (cid, Some a) <- allocs
        , a.allocation.settlement.settlementRef.id == refId
        ]
  length matching === 1
  pure (head (sortOn (\(_, a) -> a.allocation.settlement.settlementRef.id) matching))

-- Happy path: requester taps Amulet, funds the escrow's allocation, provider settles on
-- completion -> worker is actually paid in Canton Coin and the escrow becomes Paid.
testSettlementPaysWorker : Script ()
testSettlementPaysWorker = do
  registry <- AmuletRegistry.initialize AmuletRegistry.defaultAmuletRegistryConfig
  provider  <- allocateParty "provider"
  requester <- allocateParty "requester"
  worker    <- allocateParty "worker"
  arbiter   <- allocateParty "arbiter"

  -- provider is the settlement executor / featured app; requester taps test Amulet
  AmuletRegistry.featureApp registry provider
  _ <- AmuletRegistry.tapFaucet registry requester 1000.0

  now <- getTime
  let inst   = registry.instrumentId          -- InstrumentId { admin = registry.dso, id = "Amulet" }
      reward = 100.0
      refId  = "settle-happy-001"

  -- 1. create the escrow and drive it to Completed
  escrowCid <- submit (actAs [provider, requester]) do
    createCmd TaskEscrow with
      provider; requester; worker; arbiter
      taskRef = refId; amount = reward; instrumentId = inst
      status = Created; createdAt = now
      deadline = now `addRelTime` seconds 3600; resultRef = None; parentRef = None
  acceptedCid  <- submit worker do exerciseCmd escrowCid Accept
  completedCid <- submit worker do exerciseCmd acceptedCid Complete with completionRef = "artifact-1"

  -- 2. requester's wallet sees the escrow's AllocationRequest and funds it (locks Amulet)
  [reqAlloc] <- WalletClient.listRequestedAllocations requester inst
  reqAlloc.transferLeg.amount    === reward
  reqAlloc.transferLeg.sender    === requester
  reqAlloc.transferLeg.receiver  === worker
  holdingCids <- WalletClient.listHoldingCids requester inst
  enriched <- RegistryApi.getAllocationFactory registry AllocationFactory_Allocate with
    expectedAdmin    = registry.dso
    allocation       = reqAlloc
    requestedAt      = now
    inputHoldingCids = holdingCids
    extraArgs        = emptyExtraArgs
  submitWithDisclosures' requester enriched.disclosures $
    exerciseCmd enriched.factoryCid enriched.arg

  -- 3. provider settles: atomically execute the allocation transfer + mark escrow Paid
  (allocCid, _) <- allocationForTask provider refId
  ctx <- RegistryApi.getAllocation_TransferContext registry allocCid emptyMetadata
  -- the Amulet allocation is disclosed to dso/requester/provider but not the worker;
  -- disclose it (as provider, who sees it) so the worker can fetch it when claiming.
  allocDisc <- queryDisclosure' provider (coerceContractId allocCid : ContractId AmuletAllocation)
  paidCid <- submitWithDisclosures' worker (ctx.disclosures <> allocDisc) $
    exerciseCmd completedCid SettlePayment with
      allocationCid = allocCid
      extraArgs = ExtraArgs with context = ctx.choiceContext, meta = emptyMetadata

  -- 4. the worker really received the Canton Coin and the escrow is Paid
  Some task <- queryContractId provider paidCid
  task.status === Paid
  WalletClient.checkBalanceApprox worker inst reward
  pure ()

-- Refund path: a funded-but-unaccepted task is reclaimed — the requester withdraws the
-- locked allocation and gets their Amulet back; the escrow becomes Refunded.
testSettlementRefunds : Script ()
testSettlementRefunds = do
  registry <- AmuletRegistry.initialize AmuletRegistry.defaultAmuletRegistryConfig
  provider  <- allocateParty "provider"
  requester <- allocateParty "requester"
  worker    <- allocateParty "worker"
  arbiter   <- allocateParty "arbiter"

  _ <- AmuletRegistry.tapFaucet registry requester 1000.0
  now <- getTime
  let inst   = registry.instrumentId
      reward = 100.0
      refId  = "settle-refund-001"

  escrowCid <- submit (actAs [provider, requester]) do
    createCmd TaskEscrow with
      provider; requester; worker; arbiter
      taskRef = refId; amount = reward; instrumentId = inst
      status = Created; createdAt = now
      deadline = now `addRelTime` seconds 3600; resultRef = None; parentRef = None

  -- requester funds it while still in Created
  [reqAlloc] <- WalletClient.listRequestedAllocations requester inst
  holdingCids <- WalletClient.listHoldingCids requester inst
  enriched <- RegistryApi.getAllocationFactory registry AllocationFactory_Allocate with
    expectedAdmin    = registry.dso
    allocation       = reqAlloc
    requestedAt      = now
    inputHoldingCids = holdingCids
    extraArgs        = emptyExtraArgs
  submitWithDisclosures' requester enriched.disclosures $
    exerciseCmd enriched.factoryCid enriched.arg

  -- requester reclaims: withdraw the allocation + escrow -> Refunded
  (allocCid, _) <- allocationForTask provider refId
  ctx <- RegistryApi.getAllocation_WithdrawContext registry allocCid emptyMetadata
  refundedCid <- submitWithDisclosures' requester ctx.disclosures $
    exerciseCmd escrowCid SettleRefund with
      allocationCid = allocCid
      extraArgs = ExtraArgs with context = ctx.choiceContext, meta = emptyMetadata

  Some task <- queryContractId provider refundedCid
  task.status === Refunded
  -- funds are back with the requester (minus negligible fees)
  WalletClient.checkBalanceApprox requester inst 1000.0
  pure ()

-- Dispute -> refund (value-moving): a funded task is accepted, completed, then disputed;
-- the arbiter rules for the requester and ACTUALLY returns the locked Amulet via
-- `SettleResolveRefund` (Allocation_Withdraw). Worker is paid nothing; escrow -> Refunded.
testDisputeSettlementRefunds : Script ()
testDisputeSettlementRefunds = do
  registry <- AmuletRegistry.initialize AmuletRegistry.defaultAmuletRegistryConfig
  provider  <- allocateParty "provider"
  requester <- allocateParty "requester"
  worker    <- allocateParty "worker"
  arbiter   <- allocateParty "arbiter"

  _ <- AmuletRegistry.tapFaucet registry requester 1000.0
  now <- getTime
  let inst   = registry.instrumentId
      reward = 100.0
      refId  = "settle-dispute-refund-001"

  -- create -> accept -> complete (worker did the work, but it's contested)
  escrowCid <- submit (actAs [provider, requester]) do
    createCmd TaskEscrow with
      provider; requester; worker; arbiter
      taskRef = refId; amount = reward; instrumentId = inst
      status = Created; createdAt = now
      deadline = now `addRelTime` seconds 3600; resultRef = None; parentRef = None
  acceptedCid  <- submit worker do exerciseCmd escrowCid Accept
  completedCid <- submit worker do exerciseCmd acceptedCid Complete with completionRef = "artifact-1"

  -- requester funds the allocation (locks Amulet) at any point before settlement
  [reqAlloc] <- WalletClient.listRequestedAllocations requester inst
  holdingCids <- WalletClient.listHoldingCids requester inst
  enriched <- RegistryApi.getAllocationFactory registry AllocationFactory_Allocate with
    expectedAdmin    = registry.dso
    allocation       = reqAlloc
    requestedAt      = now
    inputHoldingCids = holdingCids
    extraArgs        = emptyExtraArgs
  submitWithDisclosures' requester enriched.disclosures $
    exerciseCmd enriched.factoryCid enriched.arg

  -- requester contests the result -> Disputed
  disputedCid <- submit requester do exerciseCmd completedCid Dispute with raisedBy = requester

  -- arbiter rules for the requester and returns the locked funds for real. The arbiter is
  -- not a stakeholder on the Amulet allocation, so the provider (who sees it) discloses it.
  (allocCid, _) <- allocationForTask provider refId
  ctx <- RegistryApi.getAllocation_WithdrawContext registry allocCid emptyMetadata
  allocDisc <- queryDisclosure' provider (coerceContractId allocCid : ContractId AmuletAllocation)
  refundedCid <- submitWithDisclosures' arbiter (ctx.disclosures <> allocDisc) $
    exerciseCmd disputedCid SettleResolveRefund with
      allocationCid = allocCid
      extraArgs = ExtraArgs with context = ctx.choiceContext, meta = emptyMetadata

  Some task <- queryContractId provider refundedCid
  task.status === Refunded
  -- requester whole again; worker received nothing
  WalletClient.checkBalanceApprox requester inst 1000.0
  WalletClient.checkBalanceApprox worker inst 0.0
  pure ()

-- Dispute -> pay worker (value-moving): a funded, completed task is disputed; the arbiter
-- rules for the worker and the worker claims via `SettleResolvePayWorker`
-- (Allocation_ExecuteTransfer, jointly controlled by arbiter + worker). Worker is paid;
-- escrow -> Paid.
testDisputeSettlementPaysWorker : Script ()
testDisputeSettlementPaysWorker = do
  registry <- AmuletRegistry.initialize AmuletRegistry.defaultAmuletRegistryConfig
  provider  <- allocateParty "provider"
  requester <- allocateParty "requester"
  worker    <- allocateParty "worker"
  arbiter   <- allocateParty "arbiter"

  AmuletRegistry.featureApp registry provider
  _ <- AmuletRegistry.tapFaucet registry requester 1000.0
  now <- getTime
  let inst   = registry.instrumentId
      reward = 100.0
      refId  = "settle-dispute-pay-001"

  escrowCid <- submit (actAs [provider, requester]) do
    createCmd TaskEscrow with
      provider; requester; worker; arbiter
      taskRef = refId; amount = reward; instrumentId = inst
      status = Created; createdAt = now
      deadline = now `addRelTime` seconds 3600; resultRef = None; parentRef = None
  acceptedCid  <- submit worker do exerciseCmd escrowCid Accept
  completedCid <- submit worker do exerciseCmd acceptedCid Complete with completionRef = "artifact-1"

  [reqAlloc] <- WalletClient.listRequestedAllocations requester inst
  holdingCids <- WalletClient.listHoldingCids requester inst
  enriched <- RegistryApi.getAllocationFactory registry AllocationFactory_Allocate with
    expectedAdmin    = registry.dso
    allocation       = reqAlloc
    requestedAt      = now
    inputHoldingCids = holdingCids
    extraArgs        = emptyExtraArgs
  submitWithDisclosures' requester enriched.disclosures $
    exerciseCmd enriched.factoryCid enriched.arg

  -- worker contests the (lack of) approval -> Disputed
  disputedCid <- submit worker do exerciseCmd completedCid Dispute with raisedBy = worker

  -- arbiter rules for the worker; the worker claims (joint arbiter+worker authority)
  (allocCid, _) <- allocationForTask provider refId
  ctx <- RegistryApi.getAllocation_TransferContext registry allocCid emptyMetadata
  allocDisc <- queryDisclosure' provider (coerceContractId allocCid : ContractId AmuletAllocation)
  -- joint arbiter+worker authority: build a multi-party submission with the same disclosures
  let discs = Map.values (ctx.disclosures <> allocDisc).disclosures
  paidCid <- submit (actAs [arbiter, worker] <> discloseMany discs) $
    exerciseCmd disputedCid SettleResolvePayWorker with
      allocationCid = allocCid
      extraArgs = ExtraArgs with context = ctx.choiceContext, meta = emptyMetadata

  Some task <- queryContractId provider paidCid
  task.status === Paid
  WalletClient.checkBalanceApprox worker inst reward
  pure ()

-- Status-only Approve must not strand a funded allocation: the requester approves
-- (escrow -> Paid, no money moved), and the worker can STILL claim the funded
-- allocation via SettlePayment, which is also allowed from Paid.
testSettleAfterApprove : Script ()
testSettleAfterApprove = do
  registry <- AmuletRegistry.initialize AmuletRegistry.defaultAmuletRegistryConfig
  provider  <- allocateParty "provider"
  requester <- allocateParty "requester"
  worker    <- allocateParty "worker"
  arbiter   <- allocateParty "arbiter"

  AmuletRegistry.featureApp registry provider
  _ <- AmuletRegistry.tapFaucet registry requester 1000.0
  now <- getTime
  let inst   = registry.instrumentId
      reward = 100.0
      refId  = "settle-after-approve-001"

  escrowCid <- submit (actAs [provider, requester]) do
    createCmd TaskEscrow with
      provider; requester; worker; arbiter
      taskRef = refId; amount = reward; instrumentId = inst
      status = Created; createdAt = now
      deadline = now `addRelTime` seconds 3600; resultRef = None; parentRef = None
  acceptedCid  <- submit worker do exerciseCmd escrowCid Accept
  completedCid <- submit worker do exerciseCmd acceptedCid Complete with completionRef = "artifact-1"

  -- requester funds the allocation while the task is Completed
  [reqAlloc] <- WalletClient.listRequestedAllocations requester inst
  holdingCids <- WalletClient.listHoldingCids requester inst
  enriched <- RegistryApi.getAllocationFactory registry AllocationFactory_Allocate with
    expectedAdmin    = registry.dso
    allocation       = reqAlloc
    requestedAt      = now
    inputHoldingCids = holdingCids
    extraArgs        = emptyExtraArgs
  submitWithDisclosures' requester enriched.disclosures $
    exerciseCmd enriched.factoryCid enriched.arg

  -- requester approves WITHOUT moving money (status-only) -> Paid
  approvedCid <- submit requester do exerciseCmd completedCid Approve

  -- the worker can still claim the funded allocation from the Paid escrow
  (allocCid, _) <- allocationForTask provider refId
  ctx <- RegistryApi.getAllocation_TransferContext registry allocCid emptyMetadata
  allocDisc <- queryDisclosure' provider (coerceContractId allocCid : ContractId AmuletAllocation)
  settledCid <- submitWithDisclosures' worker (ctx.disclosures <> allocDisc) $
    exerciseCmd approvedCid SettlePayment with
      allocationCid = allocCid
      extraArgs = ExtraArgs with context = ctx.choiceContext, meta = emptyMetadata

  Some task <- queryContractId provider settledCid
  task.status === Paid
  WalletClient.checkBalanceApprox worker inst reward
  pure ()

-- Cross-escrow guard: a value-moving choice on escrow A must REJECT an allocation that
-- was funded for escrow B (same requester). Without the allocation-match check the
-- requester's signatory authority on A would suffice to withdraw B's lock while marking
-- A refunded — desynchronizing both escrows.
testRefundRejectsForeignAllocation : Script ()
testRefundRejectsForeignAllocation = do
  registry <- AmuletRegistry.initialize AmuletRegistry.defaultAmuletRegistryConfig
  provider  <- allocateParty "provider"
  requester <- allocateParty "requester"
  worker    <- allocateParty "worker"
  arbiter   <- allocateParty "arbiter"

  _ <- AmuletRegistry.tapFaucet registry requester 1000.0
  now <- getTime
  let inst = registry.instrumentId
      refA = "foreign-alloc-a"
      refB = "foreign-alloc-b"
      mkTask ref amt = TaskEscrow with
        provider; requester; worker; arbiter
        taskRef = ref; amount = amt; instrumentId = inst
        status = Created; createdAt = now
        deadline = now `addRelTime` seconds 3600; resultRef = None; parentRef = None

  escrowACid <- submit (actAs [provider, requester]) do createCmd (mkTask refA 50.0)
  _escrowBCid <- submit (actAs [provider, requester]) do createCmd (mkTask refB 100.0)

  -- fund escrow B's allocation only
  reqs <- WalletClient.listRequestedAllocations requester inst
  reqB <- case [r | r <- reqs, r.settlement.settlementRef.id == refB] of
    [r] -> pure r
    _   -> abort "expected exactly one allocation request for escrow B"
  holdingCids <- WalletClient.listHoldingCids requester inst
  enriched <- RegistryApi.getAllocationFactory registry AllocationFactory_Allocate with
    expectedAdmin    = registry.dso
    allocation       = reqB
    requestedAt      = now
    inputHoldingCids = holdingCids
    extraArgs        = emptyExtraArgs
  submitWithDisclosures' requester enriched.disclosures $
    exerciseCmd enriched.factoryCid enriched.arg

  -- refunding escrow A while pointing at B's allocation must fail (allocation mismatch;
  -- the assert fires before any Allocation_Withdraw, so no registry context is needed)
  (allocBCid, _) <- allocationForTask requester refB
  submitMustFail requester do
    exerciseCmd escrowACid SettleRefund with
      allocationCid = allocBCid
      extraArgs = emptyExtraArgs
  pure ()
